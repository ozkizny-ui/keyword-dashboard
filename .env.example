# ──────────────────────────────────────────────
# 네이버 검색광고 API
# 발급: https://searchad.naver.com → 도구 → API 사용 관리
# ──────────────────────────────────────────────
NAVER_AD_API_LICENSE=여기에_API_라이선스_입력
NAVER_AD_SECRET_KEY=여기에_시크릿키_입력
NAVER_AD_CUSTOMER_ID=여기에_고객ID_입력

# ──────────────────────────────────────────────
# 네이버 개발자 센터 API (데이터랩 + 쇼핑검색)
# 발급: https://developers.naver.com → 내 애플리케이션
# ──────────────────────────────────────────────
NAVER_CLIENT_ID=여기에_클라이언트ID_입력
NAVER_CLIENT_SECRET=여기에_클라이언트시크릿_입력

# ──────────────────────────────────────────────
# Google Sheets 서비스 계정
# 발급: https://console.cloud.google.com → 서비스 계정
# ──────────────────────────────────────────────
GOOGLE_CREDENTIALS_FILE=credentials.json
